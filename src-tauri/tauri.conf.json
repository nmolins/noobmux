{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noobmux",
  "version": "0.2.4",
  "identifier": "dev.nico.noobmux",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "noobmux",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5OTBBOTQ2ODRFMzEzOTcKUldTWEUrT0VScW1RU1ZDVHo4ZDJwcCs2ZE9ua1R2UUFTU25mWjJDcHd6cWlBN2c0STE0OUlTMEcK",
      "endpoints": [
        "https://github.com/nmolins/noobmux/releases/latest/download/latest.json"
      ]
    }
  }
}
